# Set default behavior to automatically normalize line endings
* text=auto

# Force LF for all source files (cross-platform consistency)
*.cpp text eol=lf
*.h text eol=lf
*.hpp text eol=lf
*.c text eol=lf
*.cu text eol=lf
*.hip text eol=lf
*.py text eol=lf
*.sh text eol=lf
*.bash text eol=lf
*.cmake text eol=lf
*.yaml text eol=lf
*.yml text eol=lf
*.md text eol=lf
*.txt text eol=lf
*.json text eol=lf
*.xml text eol=lf
*.css text eol=lf
*.html text eol=lf
*.in text eol=lf
*.cfg text eol=lf
*.conf text eol=lf
*.toml text eol=lf
CMakeLists.txt text eol=lf
Makefile text eol=lf
Dockerfile text eol=lf
.gitignore text eol=lf
.gitattributes text eol=lf
.clang-format text eol=lf
.clang-tidy text eol=lf

# Binary files — do not touch
*.a binary
*.so binary
*.o binary
*.tar.bz2 binary
*.tar.xz binary
*.tar.gz binary
*.png binary
*.jpg binary
*.pdf binary
